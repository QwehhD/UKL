{
  "info": {
    "name": "UKL API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "token_doctor", "value": "" },
    { "key": "token_patient", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Doctor",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"doctor@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"DOCTOR\"\n}"
            }
          }
        },
        {
          "name": "Register Patient",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"patient@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"PATIENT\"\n}"
            }
          }
        },
        {
          "name": "Login Doctor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('token_doctor', json.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"doctor@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login Patient",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('token_patient', json.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"patient@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Doctor - Patients",
      "item": [
        {
          "name": "Get All Patients",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_doctor}}" }],
            "url": "{{base_url}}/patients"
          }
        },
        {
          "name": "Get Patient by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_doctor}}" }],
            "url": "{{base_url}}/patients/:id",
            "variable": [{ "key": "id", "value": "PATIENT_PROFILE_ID_HERE" }]
          }
        },
        {
          "name": "Create Patient",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/patients",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newpatient@example.com\",\n  \"password\": \"password123\",\n  \"full_name\": \"Jane Doe\",\n  \"age\": 28,\n  \"main_disease\": \"Hypertension\",\n  \"whatsapp_number\": \"081234567892\"\n}"
            }
          }
        },
        {
          "name": "Update Patient",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/patients/:id",
            "variable": [{ "key": "id", "value": "PATIENT_PROFILE_ID_HERE" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Jane Doe Updated\",\n  \"age\": 29,\n  \"main_disease\": \"Diabetes\",\n  \"whatsapp_number\": \"081234567893\"\n}"
            }
          }
        },
        {
          "name": "Delete Patient (Soft Delete)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_doctor}}" }],
            "url": "{{base_url}}/patients/:id",
            "variable": [{ "key": "id", "value": "PATIENT_PROFILE_ID_HERE" }]
          }
        }
      ]
    },
    {
      "name": "Doctor - Medications",
      "item": [
        {
          "name": "Create Medication",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/medications",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Metformin\",\n  \"slot_number\": 1,\n  \"stock\": 100\n}"
            }
          }
        },
        {
          "name": "Update Medication",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/medications/:id",
            "variable": [{ "key": "id", "value": "MEDICATION_ID_HERE" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Metformin 500mg\",\n  \"stock\": 150\n}"
            }
          }
        },
        {
          "name": "Delete Medication",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_doctor}}" }],
            "url": "{{base_url}}/medications/:id",
            "variable": [{ "key": "id", "value": "MEDICATION_ID_HERE" }]
          }
        }
      ]
    },
    {
      "name": "Doctor - Schedules",
      "item": [
        {
          "name": "Create Schedule",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/schedules",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patient_id\": \"PATIENT_USER_ID_HERE\",\n  \"medicine_id\": \"MEDICINE_ID_HERE\",\n  \"dose\": \"1 tablet\",\n  \"start_date\": \"2026-06-01\",\n  \"end_date\": \"2026-06-30\",\n  \"times\": [\"08:00\", \"12:00\", \"18:00\"]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Doctor - Verifications",
      "item": [
        {
          "name": "Get Waiting Verifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_doctor}}" }],
            "url": "{{base_url}}/doctor/verifications"
          }
        },
        {
          "name": "Approve Consumption",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_doctor}}" }],
            "url": "{{base_url}}/doctor/consumptions/:id/approve",
            "variable": [{ "key": "id", "value": "CONSUMPTION_ID_HERE" }]
          }
        },
        {
          "name": "Reject Consumption",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/doctor/consumptions/:id/reject",
            "variable": [{ "key": "id", "value": "CONSUMPTION_ID_HERE" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rejection_reason\": \"Proof image is unclear\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Patient",
      "item": [
        {
          "name": "Get Today's Schedules",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_patient}}" }],
            "url": "{{base_url}}/patient/schedules/today"
          }
        },
        {
          "name": "Upload Consumption Proof",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_patient}}" }],
            "url": "{{base_url}}/patient/consumptions",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "proof_image", "type": "file", "src": "", "description": "Image file (jpg/png, max 5MB)" },
                { "key": "schedule_id", "type": "text", "value": "SCHEDULE_ID_HERE" }
              ]
            }
          }
        },
        {
          "name": "Get Consumption History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_patient}}" }],
            "url": "{{base_url}}/patient/history"
          }
        }
      ]
    }
  ]
}
