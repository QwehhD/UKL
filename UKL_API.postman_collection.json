{
  "info": {
    "name": "UKL API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "token_doctor", "value": "" },
    { "key": "token_patient", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Doctor",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"doctor@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"DOCTOR\"\n}"
            }
          }
        },
        {
          "name": "Register Patient",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"patient@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"PATIENT\"\n}"
            }
          }
        },
        {
          "name": "Login Doctor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('token_doctor', json.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"doctor@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login Patient",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('token_patient', json.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"patient@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Doctor - Patients",
      "item": [
        {
          "name": "Get All Patients (Doctor)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/patients"
          }
        },
        {
          "name": "Get Patient by ID (Doctor)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/patients/:id",
            "variable": [{ "key": "id", "value": "PATIENT_PROFILE_ID_HERE" }]
          }
        },
        {
          "name": "Create Patient (Doctor)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/patients",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newpatient@example.com\",\n  \"password\": \"password123\",\n  \"full_name\": \"Jane Doe\",\n  \"age\": 28,\n  \"main_disease\": \"Hypertension\",\n  \"whatsapp_number\": \"081234567892\"\n}"
            }
          }
        },
        {
          "name": "Update Patient (Doctor)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/patients/:id",
            "variable": [{ "key": "id", "value": "PATIENT_PROFILE_ID_HERE" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Jane Doe Updated\",\n  \"age\": 29,\n  \"main_disease\": \"Diabetes\",\n  \"whatsapp_number\": \"081234567893\"\n}"
            }
          }
        },
        {
          "name": "Delete Patient - Soft Delete (Doctor)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/patients/:id",
            "variable": [{ "key": "id", "value": "PATIENT_PROFILE_ID_HERE" }]
          }
        }
      ]
    },
    {
      "name": "Doctor - Medications",
      "item": [
        {
          "name": "Create Medication (Doctor)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/medications",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Metformin\",\n  \"slot_number\": 1,\n  \"stock\": 100\n}"
            }
          }
        },
        {
          "name": "Update Medication (Doctor)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/medications/:id",
            "variable": [{ "key": "id", "value": "MEDICATION_ID_HERE" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Metformin 500mg\",\n  \"stock\": 150\n}"
            }
          }
        },
        {
          "name": "Delete Medication (Doctor)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/medications/:id",
            "variable": [{ "key": "id", "value": "MEDICATION_ID_HERE" }]
          }
        }
      ]
    },
    {
      "name": "Patient Profile",
      "item": [
        {
          "name": "Create Patient Profile",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_patient}}" }
            ],
            "url": "{{base_url}}/patient-profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"John Doe\",\n  \"age\": 30,\n  \"main_disease\": \"Diabetes\",\n  \"whatsapp_number\": \"081234567890\"\n}"
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_patient}}" }
            ],
            "url": "{{base_url}}/patient-profile/me"
          }
        },
        {
          "name": "Get All Patients (Doctor)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/patient-profile"
          }
        },
        {
          "name": "Update Patient Profile",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_patient}}" }
            ],
            "url": "{{base_url}}/patient-profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"John Doe Updated\",\n  \"age\": 31,\n  \"main_disease\": \"Hypertension\",\n  \"whatsapp_number\": \"081234567891\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Medicine",
      "item": [
        {
          "name": "Create Medicine (Doctor)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/medicine",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Metformin\",\n  \"slot_number\": 1,\n  \"stock\": 100\n}"
            }
          }
        },
        {
          "name": "Get All Medicines",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/medicine"
          }
        },
        {
          "name": "Get Medicine by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/medicine/:id",
            "variable": [{ "key": "id", "value": "MEDICINE_ID_HERE" }]
          }
        },
        {
          "name": "Update Medicine (Doctor)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/medicine/:id",
            "variable": [{ "key": "id", "value": "MEDICINE_ID_HERE" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stock\": 150\n}"
            }
          }
        },
        {
          "name": "Delete Medicine (Doctor)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/medicine/:id",
            "variable": [{ "key": "id", "value": "MEDICINE_ID_HERE" }]
          }
        }
      ]
    },
    {
      "name": "Schedule",
      "item": [
        {
          "name": "Create Schedule (Doctor)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/schedule",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patient_id\": \"PATIENT_USER_ID_HERE\",\n  \"medicine_id\": \"MEDICINE_ID_HERE\",\n  \"dose\": \"1 tablet\",\n  \"time\": \"08:00\"\n}"
            }
          }
        },
        {
          "name": "Get All Schedules (Doctor)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/schedule"
          }
        },
        {
          "name": "Get My Schedules (Patient)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_patient}}" }
            ],
            "url": "{{base_url}}/schedule/me"
          }
        },
        {
          "name": "Get Schedule by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/schedule/:id",
            "variable": [{ "key": "id", "value": "SCHEDULE_ID_HERE" }]
          }
        },
        {
          "name": "Update Schedule Status (Doctor)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/schedule/:id",
            "variable": [{ "key": "id", "value": "SCHEDULE_ID_HERE" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"MISSED\"\n}"
            }
          }
        },
        {
          "name": "Delete Schedule (Doctor)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/schedule/:id",
            "variable": [{ "key": "id", "value": "SCHEDULE_ID_HERE" }]
          }
        }
      ]
    },
    {
      "name": "Medication Consumption",
      "item": [
        {
          "name": "Submit Proof of Consumption (Patient)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_patient}}" }
            ],
            "url": "{{base_url}}/medication-consumption",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schedule_id\": \"SCHEDULE_ID_HERE\",\n  \"proof_image\": \"https://example.com/proof.jpg\"\n}"
            }
          }
        },
        {
          "name": "Get All Consumptions (Doctor)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/medication-consumption"
          }
        },
        {
          "name": "Get My Consumptions (Patient)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_patient}}" }
            ],
            "url": "{{base_url}}/medication-consumption/me"
          }
        },
        {
          "name": "Get Consumption by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/medication-consumption/:id",
            "variable": [{ "key": "id", "value": "CONSUMPTION_ID_HERE" }]
          }
        },
        {
          "name": "Verify Consumption - Approve (Doctor)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/medication-consumption/:id/verify",
            "variable": [{ "key": "id", "value": "CONSUMPTION_ID_HERE" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"verification_status\": \"APPROVED\"\n}"
            }
          }
        },
        {
          "name": "Verify Consumption - Reject (Doctor)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_doctor}}" }
            ],
            "url": "{{base_url}}/medication-consumption/:id/verify",
            "variable": [{ "key": "id", "value": "CONSUMPTION_ID_HERE" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"verification_status\": \"REJECTED\",\n  \"rejection_reason\": \"Proof image is unclear\"\n}"
            }
          }
        }
      ]
    }
  ]
}
