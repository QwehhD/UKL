generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  DOCTOR
  PATIENT
}

enum ScheduleStatus {
  PENDING
  WAITING_VERIFICATION
  APPROVED
  REJECTED
  MISSED
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  role       Role
  created_at DateTime @default(now())

  patientProfile          PatientProfile?
  schedulesAsDoctor       Schedule[]              @relation("DoctorSchedules")
  schedulesAsPatient      Schedule[]              @relation("PatientSchedules")
  consumptionsAsPatient   MedicationConsumption[] @relation("PatientConsumptions")
  verificationsAsDoctor   MedicationConsumption[] @relation("DoctorVerifications")
}

model PatientProfile {
  id              String    @id @default(uuid())
  user_id         String    @unique
  full_name       String
  age             Int
  main_disease    String
  whatsapp_number String
  deleted_at      DateTime?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Medicine {
  id          String @id @default(uuid())
  name        String
  slot_number Int    @unique
  stock       Int

  schedules Schedule[]
}

model Schedule {
  id          String         @id @default(uuid())
  doctor_id   String
  patient_id  String
  medicine_id String
  dose        String
  time        String
  status      ScheduleStatus @default(PENDING)
  created_at  DateTime       @default(now())

  doctor       User                    @relation("DoctorSchedules", fields: [doctor_id], references: [id])
  patient      User                    @relation("PatientSchedules", fields: [patient_id], references: [id])
  medicine     Medicine                @relation(fields: [medicine_id], references: [id])
  consumptions MedicationConsumption[]
}

model MedicationConsumption {
  id                  String         @id @default(uuid())
  schedule_id         String
  patient_id          String
  proof_image         String
  verification_status ScheduleStatus @default(WAITING_VERIFICATION)
  verified_by_id      String?
  verified_at         DateTime?
  rejection_reason    String?
  created_at          DateTime       @default(now())

  schedule     Schedule @relation(fields: [schedule_id], references: [id])
  patient      User     @relation("PatientConsumptions", fields: [patient_id], references: [id])
  verified_by  User?    @relation("DoctorVerifications", fields: [verified_by_id], references: [id])
}
