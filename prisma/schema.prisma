generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  DOCTOR
  PATIENT
}

enum ScheduleStatus {
  PENDING
  TRIGGERED
  COMPLETED
  MISSED
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  role       Role
  created_at DateTime @default(now())

  patientProfile     PatientProfile?
  schedulesAsDoctor  Schedule[] @relation("DoctorSchedules")
  schedulesAsPatient Schedule[] @relation("PatientSchedules")
}

model PatientProfile {
  id              String @id @default(uuid())
  user_id         String @unique
  full_name       String
  age             Int
  main_disease    String
  whatsapp_number String

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Medicine {
  id          String @id @default(uuid())
  name        String
  slot_number Int    @unique
  stock       Int

  schedules Schedule[]
}

model Schedule {
  id          String         @id @default(uuid())
  doctor_id   String
  patient_id  String
  medicine_id String
  dose        String
  time        String
  status      ScheduleStatus @default(PENDING)
  created_at  DateTime       @default(now())

  doctor   User     @relation("DoctorSchedules", fields: [doctor_id], references: [id])
  patient  User     @relation("PatientSchedules", fields: [patient_id], references: [id])
  medicine Medicine @relation(fields: [medicine_id], references: [id])
}
